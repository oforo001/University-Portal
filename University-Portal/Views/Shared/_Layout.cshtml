<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - University-Portal</title>

    <link rel="stylesheet" href="~/lib/bootswatch/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/menu.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/University-Portal.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body>
    <div class="side-menu">
        <nav>
            <a asp-controller="Home" asp-action="Index" class="@((ViewData["Title"]?.ToString() == "Home") ? "active" : "")">
                <i class="bi bi-house"></i> Home
            </a>
            <a asp-controller="Post" asp-action="Index" class="@((ViewData["Title"]?.ToString() == "Blog") ? "active" : "")">
                <i class="bi bi-journal-text"></i> Blog
            </a>

            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="CreateEvent" class="@((ViewData["Title"]?.ToString() == "Create Event") ? "active" : "")">
                    <i class="bi bi-plus-square"></i> Create Event
                </a>
                <a asp-controller="Post" asp-action="Create" class="@((ViewData["Title"]?.ToString() == "Create Post") ? "active" : "")">
                    <i class="bi bi-plus-square"></i> Create Post
                </a>
                <a asp-controller="UserManagement" asp-action="Index" class="@((ViewData["Title"]?.ToString() == "User Management") ? "active" : "")">
                    <i class="bi bi-people"></i> Users
                </a>
            }

            <a asp-controller="Home" asp-action="Privacy" class="@((ViewData["Title"]?.ToString() == "Privacy") ? "active" : "")">
                <i class="bi bi-shield-lock"></i> Privacy
            </a>
        </nav>

        <div class="login-section mt-auto">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <form asp-controller="Account" asp-action="Logout" method="post" class="w-100 mb-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger w-100">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary w-100">
                    <i class="bi bi-box-arrow-in-right"></i> Login
                </a>
            }
        </div>
    </div>

    <div class="content-wrapper">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <footer class="border-top footer text-muted mt-auto">
        <div class="container">
            &copy; 2025 - University-Portal - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
</body>
</html>