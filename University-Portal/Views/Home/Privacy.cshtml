@{
    ViewData["Title"] = "Polityka Prywatności";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">

                    <h1 class="mb-4 fw-bold">@ViewData["Title"]</h1>

                    <p class="lead text-muted">
                        Twoja prywatność jest dla nas ważna. Niniejsza polityka prywatności opisuje, w jaki sposób system rejestracji wydarzeń przetwarza i chroni dane osobowe użytkowników. Projekt został przygotowany jako projekt końcowy w celu obrony pracy inżynierskiej.
                    </p>

                    <hr class="my-4" />

                    <section class="mb-4">
                        <h4 class="fw-semibold mb-3">
                            <i class="bi bi-database"></i> Jakie dane zbieramy?
                        </h4>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">Imię i nazwisko</li>
                            <li class="list-group-item">Adres e-mail</li>
                            <li class="list-group-item">Numer telefonu (opcjonalnie)</li>
                            <li class="list-group-item">Jednostka organizacyjna lub kierunek studiów (jeśli dotyczy)</li>
                        </ul>
                    </section>

                    <section class="mb-4">
                        <h4 class="fw-semibold mb-3">
                            <i class="bi bi-gear"></i> Cel przetwarzania danych
                        </h4>
                        <p>Zgromadzone dane wykorzystywane są wyłącznie do:</p>
                        <ul>
                            <li>obsługi rejestracji i komunikacji związanej z wydarzeniami,</li>
                            <li>zarządzania frekwencją i uczestnictwem,</li>
                            <li>celów statystycznych w ramach projektu uczelnianego.</li>
                        </ul>
                    </section>

                    <section class="mb-4">
                        <h4 class="fw-semibold mb-3">
                            <i class="bi bi-share"></i> Udostępnianie danych
                        </h4>
                        <p>
                            Dane użytkowników nie są przekazywane podmiotom trzecim,
                            z wyjątkiem sytuacji wymaganych przez obowiązujące przepisy prawa
                            lub za wyraźną zgodą użytkownika.
                        </p>
                    </section>

                    <section class="mb-4">
                        <h4 class="fw-semibold mb-3">
                            <i class="bi bi-shield-lock"></i> Bezpieczeństwo danych
                        </h4>
                        <p>
                            Stosujemy odpowiednie środki techniczne i organizacyjne,
                            aby chronić dane przed nieuprawnionym dostępem, utratą
                            lub nieautoryzowaną modyfikacją.
                        </p>
                    </section>

                    <section class="mb-4">
                        <h4 class="fw-semibold mb-3">
                            <i class="bi bi-person-check"></i> Twoje prawa
                        </h4>
                        <ul>
                            <li>Dostęp do swoich danych</li>
                            <li>Poprawianie danych</li>
                            <li>Usunięcie lub ograniczenie przetwarzania</li>
                            <li>Wniesienie sprzeciwu wobec przetwarzania</li>
                            <li>Cofnięcie zgody w dowolnym momencie</li>
                        </ul>
                    </section>

                    <hr class="my-4" />

                    <section>
                        <h4 class="fw-semibold mb-3">
                            <i class="bi bi-envelope"></i> Kontakt
                        </h4>

                        <div class="bg-light rounded-3 p-4">
                            <p class="mb-2">
                                Projekt końcowy przygotowany przez:
                            </p>

                            <ul class="mb-3">
                                <li><strong>Oleksii Forostianov</strong></li>
                                <li><strong>Adrian Błażejewski</strong></li>
                            </ul>

                            <p class="mb-0 text-muted">
                                W sprawach związanych z ochroną danych osobowych prosimy o kontakt:
                                <br />
                                <a href="pzx115136@student.poznan.merito.pl" class="fw-semibold">
                                    admin@university.com
                                </a>
                            </p>
                        </div>
                    </section>

                </div>
            </div>

        </div>
    </div>
</div>