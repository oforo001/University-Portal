@model IEnumerable<University_Portal.ViewModels.Home.EventViewModel>
@{
    ViewData["Title"] = "Nadchodzące wydarzenia";
    var registeredEventIds = ViewBag.RegisteredEventIds as List<int> ?? new List<int>();
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Nadchodzące wydarzenia</h2>

    <div id="toastContainer" style="position: fixed; top: 20px; right: 20px; z-index: 1055;"></div>

    @if (Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var ev in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm" style="min-height: 550px; position:relative;">
                        @if (!string.IsNullOrEmpty(ev.ImagePath))
                        {
                            <div style="position:relative;">
                                @if (registeredEventIds.Contains(ev.Id))
                                {
                                    <span style="position:absolute; top:10px; right:10px; z-index:2;">
                                        <span style="display:inline-block;width:20px;height:20px;background-color:#28a745;border-radius:50%;border:2px solid #fff;box-shadow:0 0 5px #888;"></span>
                                    </span>
                                }
                                <img src="~/@ev.ImagePath" alt="Obraz wydarzenia"
                                     class="card-img-top"
                                     style="height: 300px; object-fit: cover; border-radius: 0.6rem 0.6rem 0 0;"
                                     onerror="this.onerror=null;this.src='/images/no-image.png';" />
                            </div>
                        }
                        else
                        {
                            <div style="position:relative;">
                                @if (registeredEventIds.Contains(ev.Id))
                                {
                                    <span style="position:absolute; top:10px; right:10px; z-index:2;">
                                        <span style="display:inline-block;width:20px;height:20px;background-color:#28a745;border-radius:50%;border:2px solid #fff;box-shadow:0 0 5px #888;"></span>
                                    </span>
                                }
                                <div class="bg-light d-flex align-items-center justify-content-center"
                                     style="height: 300px; border-radius: 0.6rem 0.6rem 0 0;">
                                    <span class="text-muted" style="font-size:1.3em;">Brak obrazu</span>
                                </div>
                            </div>
                        }

                        <div class="card-body d-flex flex-column p-4">
                            <h4 class="card-title text-center mb-3">@ev.Title</h4>
                            <div class="mb-3 text-muted" style="min-height: 70px;">
                                @ev.Description
                            </div>
                            <p class="card-text mb-2 mt-auto">
                                <strong>Data:</strong> @ev.Date.ToString("dd-MM-yyyy HH:mm")<br />
                                <strong>Lokalizacja:</strong> @ev.Location<br />
                                <strong>Dostępne miejsca:</strong>
                                @if (ev.FreeSlots > 0)
                                {
                                    <span class="text-success fw-bold">@ev.FreeSlots</span>
                                }
                                else
                                {
                                    <span class="text-danger fw-bold">Brak wolnych miejsc</span>
                                }
                            </p>

                            @if (registeredEventIds.Contains(ev.Id))
                            {
                                <form class="cancelForm" data-id="@ev.Id">
                                    <button type="submit" class="btn btn-danger mt-2 w-100">Anuluj rejestrację</button>
                                </form>
                            }
                            else
                            {
                                <form class="registerForm" data-id="@ev.Id">
                                    <button type="submit" class="btn btn-info text-white mt-3 w-100" @(ev.FreeSlots <= 0 ? "disabled" : "")>
                                        Zarejestruj się
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">Brak dostępnych wydarzeń.</div>
    }
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(function () {

            function csrf() {
                return $('input[name="__RequestVerificationToken"]').val();
            }

            window.showToast = function (success, message) {
                const toastId = "toast_" + Date.now();
                const typeClass = success ? "bg-success" : "bg-danger";

                const toastHtml = `
                            <div id="${toastId}" class="toast show text-white ${typeClass} mb-2 shadow"
                                 role="alert" style="cursor:pointer;">
                                <div class="toast-header ${typeClass} text-white border-0">
                                    <strong class="me-auto">${success ? "Sukces" : "Błąd"}</strong>
                                    <button type="button" class="btn-close btn-close-white"></button>
                                </div>
                                <div class="toast-body">
                                    ${message}
                                </div>
                            </div>
                        `;
                $("#toastContainer").append(toastHtml);

                const toast = $("#" + toastId);
                toast.on("click", function () { toast.fadeOut(300, () => toast.remove()); });

                setTimeout(() => { toast.fadeOut(300, () => toast.remove()); }, 10000);
            };

            $(".registerForm").submit(function (e) {
                e.preventDefault();
                const form = $(this);
                const id = form.data("id");
                const btn = form.find("button");
                btn.prop("disabled", true);

                $.ajax({
                    type: "POST",
                    url: `/Home/RegisterForEvent?id=${id}`,
                    headers: { 'RequestVerificationToken': csrf() },
                    success: function (res) {
                        showToast(res.success, res.message);
                        if (res.success) {
                            form.replaceWith(`
                                        <form class="cancelForm" data-id="${id}">
                                            <button type="submit" class="btn btn-danger mt-2 w-100">Anuluj rejestrację</button>
                                        </form>
                                    `);
                        }
                    },
                    error: function () {
                        showToast(false, "Wystąpił nieoczekiwany błąd.");
                    },
                    complete: function () { btn.prop("disabled", false); }
                });
            });

            $(document).on("submit", ".cancelForm", function (e) {
                e.preventDefault();
                const form = $(this);
                const id = form.data("id");
                const btn = form.find("button");
                btn.prop("disabled", true);

                $.ajax({
                    type: "POST",
                    url: `/Home/Cancel?id=${id}`,
                    headers: { 'RequestVerificationToken': csrf() },
                    success: function (res) {
                        showToast(res.success, res.message);
                        if (res.success) {
                            form.replaceWith(`
                                        <form class="registerForm" data-id="${id}">
                                            <button type="submit" class="btn btn-info text-white mt-3 w-100">
                                                Zarejestruj się
                                            </button>
                                        </form>
                                    `);
                        }
                    },
                    error: function () {
                        showToast(false, "Wystąpił nieoczekiwany błąd.");
                    },
                    complete: function () { btn.prop("disabled", false); }
                });
            });

        });
    </script>
}