@model IEnumerable<University_Portal.ViewModels.Home.EventViewModel>
@using University_Portal.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "Nadchodzące wydarzenia";
    var registeredEventIds = ViewBag.RegisteredEventIds as List<int> ?? new List<int>();
}

@Html.AntiForgeryToken()

<link rel="stylesheet" href="~/css/events.css" asp-append-version="true" />

<div class="container mt-4">

    @{
        string fullName = "";
        if (User.Identity.IsAuthenticated)
        {
            var appUser = await UserManager.GetUserAsync(User);
            if (appUser != null)
            {
                fullName = appUser.FullName;
            }
        }
    }

    @if (!string.IsNullOrEmpty(fullName))
    {
        <h4 class="mb-3 fw-bold text-dark">Witaj, @fullName!</h4>
    }

    <h2 class="text-center mb-4">Nadchodzące wydarzenia</h2>

    <div id="toastContainer" class="position-fixed top-0 end-0 p-3" style="z-index:1055;"></div>

    @if (Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

            @foreach (var ev in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm" style="min-height: 550px; position:relative;">

                        @if (!string.IsNullOrEmpty(ev.ImagePath))
                        {
                            <img src="~/@ev.ImagePath"
                                 class="card-img-top"
                                 style="height:300px; object-fit:cover;"
                                 onerror="this.onerror=null;this.src='/images/no-image.png';" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center"
                                 style="height:300px;">
                                <span class="text-muted">Brak obrazu</span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column p-4">

                            <h4 class="text-center fw-bold mb-3">@ev.Title</h4>

                            <div class="text-muted event-desc" id="desc-@ev.Id">
                                @ev.Description
                            </div>

                            <div class="desc-toggle" data-id="@ev.Id">
                                <svg class="arrow-icon" viewBox="0 0 24 24">
                                    <path d="M6 9l6 6 6-6" />
                                </svg>
                            </div>

                            <div class="mt-auto small text-muted mt-3">
                                <div><strong>Data:</strong> @ev.Date.ToString("dd-MM-yyyy HH:mm")</div>
                                <div><strong>Lokalizacja:</strong> @ev.Location</div>
                                <div>
                                    <strong>Dostępne miejsca:</strong>
                                    @if (ev.FreeSlots > 0)
                                    {
                                        <span class="text-success fw-bold">@ev.FreeSlots</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">Brak</span>
                                    }
                                </div>
                            </div>

                            @if (registeredEventIds.Contains(ev.Id))
                            {
                                <form class="cancelForm" data-id="@ev.Id">
                                    <button type="submit" class="btn btn-danger mt-2 w-100">
                                        Anuluj rejestrację
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form class="registerForm" data-id="@ev.Id">
                                    <button type="submit"
                                            class="btn btn-info text-white mt-3 w-100"
                                    @(ev.FreeSlots <= 0 ? "disabled" : "")>
                                        Zarejestruj się
                                    </button>
                                </form>
                            }

                        </div>
                    </div>
                </div>
            }

        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h3>Brak dostępnych wydarzeń</h3>
        </div>
    }
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(function () {

            function csrf() {
                return $('input[name="__RequestVerificationToken"]').val();
            }

            window.showToast = function (success, message) {
                const toastId = "toast_" + Date.now();
                const typeClass = success ? "bg-success" : "bg-danger";

                const toastHtml = `
                                    <div id="${toastId}" class="toast show text-white ${typeClass} mb-2 shadow"
                                         role="alert" style="cursor:pointer;">
                                        <div class="toast-header ${typeClass} text-white border-0">
                                            <strong class="me-auto">${success ? "Sukces" : "Błąd"}</strong>
                                            <button type="button" class="btn-close btn-close-white"></button>
                                        </div>
                                        <div class="toast-body">
                                            ${message}
                                        </div>
                                    </div>
                                `;
                $("#toastContainer").append(toastHtml);

                const toast = $("#" + toastId);
                toast.on("click", function () { toast.fadeOut(300, () => toast.remove()); });

                setTimeout(() => { toast.fadeOut(300, () => toast.remove()); }, 10000);
            };

            $(".registerForm").submit(function (e) {
                e.preventDefault();
                const form = $(this);
                const id = form.data("id");
                const btn = form.find("button");
                btn.prop("disabled", true);

                $.ajax({
                    type: "POST",
                    url: `/Home/RegisterForEvent?id=${id}`,
                    headers: { 'RequestVerificationToken': csrf() },
                    success: function (res) {
                        showToast(res.success, res.message);
                        if (res.success) {
                            form.replaceWith(`
                                                <form class="cancelForm" data-id="${id}">
                                                    <button type="submit" class="btn btn-danger mt-2 w-100">Anuluj rejestrację</button>
                                                </form>
                                            `);
                        }
                    },
                    error: function () {
                        showToast(false, "Wystąpił nieoczekiwany błąd.");
                    },
                    complete: function () { btn.prop("disabled", false); }
                });
            });

            $(document).on("submit", ".cancelForm", function (e) {
                e.preventDefault();
                const form = $(this);
                const id = form.data("id");
                const btn = form.find("button");
                btn.prop("disabled", true);

                $.ajax({
                    type: "POST",
                    url: `/Home/Cancel?id=${id}`,
                    headers: { 'RequestVerificationToken': csrf() },
                    success: function (res) {
                        showToast(res.success, res.message);
                        if (res.success) {
                            form.replaceWith(`
                                                <form class="registerForm" data-id="${id}">
                                                    <button type="submit" class="btn btn-info text-white mt-3 w-100">
                                                        Zarejestruj się
                                                    </button>
                                                </form>
                                            `);
                        }
                    },
                    error: function () {
                        showToast(false, "Wystąpił nieoczekiwany błąd.");
                    },
                    complete: function () { btn.prop("disabled", false); }
                });
            });
            $(document).on("click", ".desc-toggle", function () {

                const id = $(this).data("id");
                const desc = $("#desc-" + id);

                desc.toggleClass("expanded");

                $(this).toggleClass("active");
            });

        });
    </script>
}