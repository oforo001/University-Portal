@model IEnumerable<University_Portal.Models.Event>

@{
    ViewData["Title"] = "Panel Administratora";
}

@Html.AntiForgeryToken()

<link rel="stylesheet" href="~/css/action_effects.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/events.css" asp-append-version="true" />

<style>
    
</style>

<div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3"></div>

<div id="pageWrapper">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Zarządzaj wydarzeniami</h3>

        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-primary shadow-sm"
               asp-controller="Admin"
               asp-action="CreateEvent">
                + Utwórz wydarzenie
            </a>
        }
    </div>

    @if (Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

            @foreach (var ev in Model)
            {
                <div class="col event-card" data-event-id="@ev.Id">
                    <div class="card h-100 shadow-sm">

                        @if (!string.IsNullOrEmpty(ev.ImagePath))
                        {
                            <img src="~/@ev.ImagePath"
                                 class="card-img-top"
                                 style="height:300px; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center"
                                 style="height:300px;">
                                <span class="text-muted">Brak zdjęcia</span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column p-4">

                            <h4 class="text-center fw-bold mb-3">@ev.Title</h4>

                            <!-- DESCRIPTION -->
                            <div class="text-muted event-desc" id="desc-@ev.Id">
                                @ev.Description
                            </div>

                            <!-- MINIMAL ARROW -->
                            <div class="desc-toggle" data-id="@ev.Id">
                                <svg class="arrow-icon" viewBox="0 0 24 24">
                                    <path d="M6 9l6 6 6-6" />
                                </svg>
                            </div>

                            <div class="mt-auto small text-muted mt-3">
                                <div><strong>Data:</strong> @ev.Date.ToString("dd-MM-yyyy HH:mm")</div>
                                <div><strong>Lokalizacja:</strong> @ev.Location</div>
                                <div><strong>Maks. uczestników:</strong> @ev.MaxParticipants</div>
                            </div>

                        </div>

                        <div class="card-footer d-flex justify-content-end gap-2 px-4 py-3 action-bar">

                            <a asp-action="EditEvent"
                               asp-route-id="@ev.Id"
                               class="btn btn-action btn-view">
                                Zobacz
                            </a>

                            <button class="btn btn-action btn-delete open-delete"
                                    data-event-id="@ev.Id">
                                Usuń
                            </button>

                        </div>

                    </div>
                </div>
            }

        </div>
    }
    else
    {
        <div class="no-events text-center py-5">
            <h3>Brak dostępnych wydarzeń</h3>
        </div>
    }

</div>

<!-- DELETE MODAL -->
<div id="deleteOverlay" class="delete-overlay">
    <div class="delete-modal shadow rounded-4 p-4">

        <h5 class="fw-bold mb-2">Usuń event?</h5>
        <p class="text-muted mb-4">Ta operacja jest nieodwracalna.</p>

        <div class="d-flex justify-content-end gap-2">
            <button id="cancelDelete" class="btn btn-secondary px-4">Anuluj</button>
            <button id="confirmDelete" class="btn btn-danger px-4">Usuń</button>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(function () {

            // ===== TOGGLE DESCRIPTION =====
            $(".desc-toggle").click(function () {

                const id = $(this).data("id");
                const desc = $("#desc-" + id);

                desc.toggleClass("expanded");
                $(this).toggleClass("active");
            });

            // ===== DELETE LOGIC (UNCHANGED) =====
            let selectedEventId = null;

            function csrf() {
                return $('input[name="__RequestVerificationToken"]').val();
            }

            $(".open-delete").click(function () {
                selectedEventId = $(this).data("event-id");
                $("#deleteOverlay").addClass("active");
            });

            $("#cancelDelete").click(function () {
                selectedEventId = null;
                $("#deleteOverlay").removeClass("active");
            });

            $("#confirmDelete").click(function () {

                if (!selectedEventId) return;

                const btn = $(this);
                btn.prop("disabled", true);

                $.ajax({
                    url: "@Url.Action("DeleteEvent", "Admin")",
                    type: "POST",
                    headers: { 'RequestVerificationToken': csrf() },
                    data: { id: selectedEventId },

                    success: function (res) {
                        const card = $(`.event-card[data-event-id='${selectedEventId}']`);
                        card.fadeOut(300, function () { $(this).remove(); });
                        $("#deleteOverlay").removeClass("active");
                    },

                    error: function () {
                        alert("Błąd usuwania");
                    },

                    complete: function () {
                        btn.prop("disabled", false);
                        selectedEventId = null;
                    }
                });
            });

        });
    </script>
}