@model University_Portal.ViewModels.AdminViewModels.EventCreateViewModel

@{
    ViewData["Title"] = "Edytuj wydarzenie";
}

<link rel="stylesheet" href="~/css/createPost.css" asp-append-version="true" />

<div class="content-wrapper">
    <div class="form-card">

        <div class="page-header">
            <h2>@ViewData["Title"]</h2>
            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">
                Powrót do wydarzeń
            </a>
        </div>

        <hr />

        <form id="editEventForm"
              asp-action="EditEvent"
              asp-route-id="@ViewContext.RouteData.Values["id"]"
              method="post"
              enctype="multipart/form-data">

            <div class="validation-summary">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            </div>

            <div class="form-group">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="Tytuł wydarzenia" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Opisz wydarzenie"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Date" class="form-label"></label>
                <input asp-for="Date"
                       type="datetime-local"
                       class="form-control"
                       value="@Model.Date.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Location" class="form-label"></label>
                <input asp-for="Location" class="form-control" placeholder="Budynek, sala lub link online" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MaxParticipants" class="form-label"></label>
                <input asp-for="MaxParticipants" type="number" min="1" class="form-control" />
                <span asp-validation-for="MaxParticipants" class="text-danger"></span>
            </div>

            <div class="form-group">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div class="mb-2">
                        <label class="form-label">Aktualne zdjęcie</label><br />
                        <img src="~/@Model.ImagePath" style="max-width:220px; border-radius:8px;" />
                    </div>
                }

                <label asp-for="Image" class="form-label">Prześlij nowe zdjęcie (opcjonalnie)</label>
                <input asp-for="Image"
                       type="file"
                       class="form-control"
                       accept=".jpg,.jpeg,.png,.gif" />
                <span asp-validation-for="Image" class="text-danger"></span>
                <small class="form-text text-muted">
                    Dozwolone formaty: .jpg, .jpeg, .png, .gif. Maksymalny rozmiar 4 MB.
                </small>
            </div>

            <div class="btn-group-actions">
                <button type="submit" id="submitBtn" class="btn btn-primary">
                    Aktualizuj
                </button>

                <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">
                    Anuluj
                </a>
            </div>
        </form>

        @if (Model.RegisteredUsers?.Any() == true)
        {
            <div class="mt-5">
                <h4 class="mb-3">Zarejestrowani użytkownicy</h4>
                <div class="table-responsive shadow-sm rounded-3">
                    <table class="table align-middle mb-0 custom-blue-table">
                        <thead>
                            <tr>
                                <th scope="col"></th>
                                <th scope="col">Nazwa użytkownika</th>
                                <th scope="col">E-mail</th>
                                <th scope="col">Zarejestrowano</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.RegisteredUsers.Count; i++)
                            {
                                var user = Model.RegisteredUsers[i];
                                <tr>
                                    <th scope="row">@((i + 1))</th>
                                    <td>@user.FullName</td>
                                    <td><a href="mailto:@user.Email" class="text-decoration-none">@user.Email</a></td>
                                    <td>
                                        <span class="badge bg-primary rounded-pill">
                                            @user.RegisteredAt.ToLocalTime().ToString("dd-MM-yyyy HH:mm")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById("editEventForm")
            .addEventListener("submit", async function (e) {
                e.preventDefault();
                const form = this;
                const btn = document.getElementById("submitBtn");

                if (!$(form).valid()) return;

                btn.disabled = true;
                btn.innerText = "Aktualizowanie...";

                const formData = new FormData(form);

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: formData
                    });

                    if (response.ok) {
                        window.location.href = "/Admin/Index";
                    } else {
                        const error = await response.json();
                        alert(error.message || "Aktualizacja nie powiodła się.");
                        btn.disabled = false;
                        btn.innerText = "Aktualizuj";
                    }
                } catch (err) {
                    alert("Wystąpił nieoczekiwany błąd.");
                    btn.disabled = false;
                    btn.innerText = "Aktualizuj";
                }
            });
    </script>
}