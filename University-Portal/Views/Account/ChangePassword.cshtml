@using University_Portal.ViewModels
@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="account-container">
    <div class="account-box">
        <h2 class="text-center mb-4">Zmiana hasła</h2>

        <form id="changePasswordForm" asp-action="ChangePassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmNewPassword" class="form-label"></label>
                <input asp-for="ConfirmNewPassword" class="form-control" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
            </div>

            <input type="submit" value="Zmień hasło" class="btn btn-success w-100" />

            <div class="text-center mt-3">
                <a asp-controller="Account" asp-action="Login" class="text-decoration-none">
                    Powrót do logowania
                </a>
            </div>
        </form>

        <div id="toastContainer" style="position: fixed; top:20px; right:20px; z-index:1055;"></div>

    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(function () {

            function showToast(success, message) {

                const toastId = "toast_" + Date.now();
                const typeClass = success ? "bg-success" : "bg-danger";

                const toastHtml = `
                    <div id="${toastId}" class="toast show text-white ${typeClass} mb-2 shadow" role="alert" style="cursor:pointer;">
                        <div class="toast-header ${typeClass} text-white border-0">
                            <strong class="me-auto">${success ? "Sukces" : "Błąd"}</strong>
                            <button type="button" class="btn-close btn-close-white"></button>
                        </div>
                        <div class="toast-body">
                            ${message}
                        </div>
                    </div>
                `;

                $("#toastContainer").append(toastHtml);

                const toast = $("#" + toastId);

                toast.on("click", function () {
                    toast.fadeOut(300, () => toast.remove());
                });

                setTimeout(() => {
                    toast.fadeOut(300, () => toast.remove());
                }, 10000);
            }

            $("#changePasswordForm").submit(function (e) {

                e.preventDefault();

                const form = $(this);
                const btn = form.find("input[type=submit]");

                btn.prop("disabled", true);

                $.ajax({
                    type: "POST",
                    url: form.attr("action"),
                    data: form.serialize(),

                    success: function (res) {

                        if (res.success) {

                            showToast(true, res.message);

                            setTimeout(() => {
                                window.location.href = res.redirectUrl;
                            }, 800);

                        } else if (res.errors) {

                            showToast(false, res.errors.join("<br>"));

                        }
                    },

                    error: function () {

                        showToast(false, "Wystąpił nieoczekiwany błąd.");

                    },

                    complete: function () {

                        btn.prop("disabled", false);

                    }
                });

            });

        });
    </script>
}