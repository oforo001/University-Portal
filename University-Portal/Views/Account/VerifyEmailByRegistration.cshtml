@using University_Portal.ViewModels
@model VerifyEmailViewModel

@{
    ViewData["Title"] = "Weryfikacja e-mail";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="account-container">
    <div class="account-box">
        <h2 class="text-center mb-4">Weryfikacja e-mail</h2>

        <form id="verifyEmailForm" asp-action="VerifyEmailByRegistration" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Adres e-mail</label>
                <input asp-for="Email" class="form-control" readonly />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Token" class="form-label">Kod weryfikacyjny</label>
                <input asp-for="Token" class="form-control" maxlength="6" placeholder="Wpisz kod weryfikacyjny" />
                <span asp-validation-for="Token" class="text-danger"></span>
            </div>

            <input type="submit" value="Zweryfikuj" class="btn btn-success w-100" />

            <div class="text-center mt-2">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none mt-3">Powrót</a>
            </div>
        </form>

        <div id="toastContainer" style="position: fixed; top: 20px; right: 20px; z-index: 1055;"></div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(function () {
            function csrf() {
                return $('input[name="__RequestVerificationToken"]').val();
            }

            window.showToast = function (success, message) {
                const toastId = "toast_" + Date.now();
                const typeClass = success ? "bg-success" : "bg-danger";

                const toastHtml = `
                                    <div id="${toastId}" class="toast show text-white ${typeClass} mb-2 shadow" role="alert" style="cursor:pointer;">
                                        <div class="toast-header ${typeClass} text-white border-0">
                                            <strong class="me-auto">${success ? "Sukces" : "Błąd"}</strong>
                                            <button type="button" class="btn-close btn-close-white"></button>
                                        </div>
                                        <div class="toast-body">
                                            ${message}
                                        </div>
                                    </div>
                                `;
                $("#toastContainer").append(toastHtml);

                const toast = $("#" + toastId);
                toast.on("click", function () {
                    toast.fadeOut(300, () => toast.remove());
                });

                setTimeout(() => {
                    toast.fadeOut(300, () => toast.remove());
                }, 10000);
            };

            $("#verifyEmailForm").submit(function (e) {
                e.preventDefault();
                const form = $(this);
                const btn = form.find("input[type=submit]");
                btn.prop("disabled", true);

                $.ajax({
                    type: "POST",
                    url: form.attr("action"),
                    data: form.serialize(),
                    success: function (res) {
                        if (res.success) {
                            showToast(true, res.message);
                            setTimeout(() => {
                                window.location.href = res.redirectUrl;
                            }, 1500);
                        } else if (res.errors) {
                            showToast(false, res.errors.join("<br>"));
                        }
                    },
                    error: function () {
                        showToast(false, "Wystąpił nieoczekiwany błąd.");
                    },
                    complete: function () {
                        btn.prop("disabled", false);
                    }
                });
            });
        });
    </script>
}