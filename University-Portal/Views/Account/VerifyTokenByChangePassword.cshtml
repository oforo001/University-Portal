@using University_Portal.ViewModels
@model VerifyEmailViewModel

@{
    ViewData["Title"] = "Weryfikacja e-mail";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="account-container">
    <div class="account-box">
        <h2 class="text-center mb-4">Weryfikacja adresu e-mail</h2>

        <form id="verifyEmailForm" asp-action="VerifyTokenByChangePassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Email" />

            <div class="mb-3">
                <label asp-for="Token" class="form-label">Kod weryfikacyjny</label>
                <input asp-for="Token" class="form-control" required maxlength="6" />
                <span asp-validation-for="Token" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success w-100" id="verifyBtn">
                <span id="verifyText">Zweryfikuj</span>
                <span id="verifySpinner" class="spinner-border spinner-border-sm ms-2 d-none"></span>
            </button>

            <div class="d-flex justify-content-end mt-3">
                <a href="#" id="resendCodeLink" class="text-decoration-none">
                    <span id="resendText">Wyślij ponownie kod</span>
                    <span id="resendSpinner" class="spinner-border spinner-border-sm ms-1 d-none"></span>
                </a>
            </div>

            <div class="text-center mt-2">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Powrót</a>
            </div>
        </form>

        <div id="toastContainer" style="position: fixed; top: 20px; right: 20px; z-index: 1055;"></div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            function csrf() {
                return $('input[name="__RequestVerificationToken"]').val();
            }

            function showToast(success, message) {
                const toastId = "toast_" + Date.now();
                const typeClass = success ? "bg-success" : "bg-danger";

                const toastHtml = `
                            <div id="${toastId}" class="toast show text-white ${typeClass} mb-2 shadow" role="alert" style="cursor:pointer;">
                                <div class="toast-header ${typeClass} text-white border-0">
                                    <strong class="me-auto">${success ? "Sukces" : "Błąd"}</strong>
                                    <button type="button" class="btn-close btn-close-white"></button>
                                </div>
                                <div class="toast-body">
                                    ${message}
                                </div>
                            </div>
                        `;
                $("#toastContainer").append(toastHtml);

                const toast = $("#" + toastId);
                toast.on("click", function () {
                    toast.fadeOut(300, () => toast.remove());
                });
                setTimeout(() => {
                    toast.fadeOut(300, () => toast.remove());
                }, 10000);
            }

            $("#verifyEmailForm").submit(function (e) {
                e.preventDefault();

                const form = $(this);
                const btn = $("#verifyBtn");
                const spinner = $("#verifySpinner");
                const text = $("#verifyText");

                btn.prop("disabled", true);
                spinner.removeClass("d-none");
                text.text("Weryfikacja...");

                $.ajax({
                    type: "POST",
                    url: form.attr("action"),
                    data: form.serialize(),

                    success: function (res) {
                        if (res.success) {
                            showToast(true, res.message);

                            setTimeout(() => {
                                window.location.href = res.redirectUrl;
                            }, 1500);
                        }
                        else if (res.errors) {
                            showToast(false, res.errors.join("<br>"));
                        }
                    },

                    error: function () {
                        showToast(false, "Wystąpił nieoczekiwany błąd.");
                    },

                    complete: function () {
                        btn.prop("disabled", false);
                        spinner.addClass("d-none");
                        text.text("Zweryfikuj");
                    }
                });
            });

            $("#resendCodeLink").click(function (e) {
                e.preventDefault();

                const email = $("input[name='Email']").val();
                const spinner = $("#resendSpinner");
                const text = $("#resendText");

                if (!email)
                    return showToast(false, "Nie znaleziono adresu e-mail.");

                spinner.removeClass("d-none");
                text.text("Wysyłanie...");

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("SendPasswordResetToken", "Account")',
                    data: { email: email, __RequestVerificationToken: csrf() },

                    success: function (res) {
                        if (res.success) {
                            showToast(true, res.message);
                        } else if (res.errors) {
                            showToast(false, res.errors.join("<br>"));
                        }
                    },

                    error: function () {
                        showToast(false, "Nie udało się wysłać ponownie kodu weryfikacyjnego.");
                    },

                    complete: function () {
                        spinner.addClass("d-none");
                        text.text("Wyślij ponownie kod");
                    }
                });
            });

        });
    </script>
}